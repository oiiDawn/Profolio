# Copy to `.env.local` and fill in values from Supabase:
# Dashboard → Project Settings → API → Project URL & anon public key
#
# Writing / MDX: run `supabase/writing.sql` in the SQL editor, then create a
# public Storage bucket named `writing` for `.mdx` files referenced by `file_path`.
#
# Service role (Dashboard → Project Settings → API → service_role secret):
# Only for local script `pnpm upload-writing` — never commit real values or use in NEXT_PUBLIC_*.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Projects page: GitHub public repos (server-side only; not exposed to the browser)
# GITHUB_USERNAME defaults to siteGithubUsername in lib/site.ts if unset.
GITHUB_USERNAME=your-github-login
# Optional: raises GitHub API rate limit; never use NEXT_PUBLIC_* for tokens.
# GITHUB_TOKEN=ghp_...
