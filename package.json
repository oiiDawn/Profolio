{
  "name": "personal-homepage",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.18.2"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/lib tests/scripts",
    "test:component": "vitest run tests/frontend",
    "test:data": "vitest run tests/data",
    "test:coverage": "cross-env VITEST_ENFORCE_THRESHOLDS=1 vitest run --coverage",
    "test:e2e": "playwright test tests/e2e/smoke.spec.ts tests/e2e/writing.spec.ts",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts --project=desktop-chromium --project=mobile-chrome",
    "test:e2e:writing": "playwright test tests/e2e/writing.spec.ts --project=desktop-chromium",
    "test:visual": "playwright test tests/e2e/visual.spec.ts --project=desktop-chromium --project=mobile-chrome",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts --project=desktop-chromium",
    "check": "pnpm check:fast",
    "check:fast": "pnpm lint && pnpm typecheck && pnpm typecheck:tests && pnpm test:unit && pnpm test:component && pnpm test:data",
    "check:full": "pnpm check:fast && pnpm build && pnpm test:e2e && pnpm test:a11y",
    "ci:pr": "pnpm check:fast && pnpm build && pnpm test:e2e",
    "ci:nightly": "pnpm check:full && pnpm test:visual",
    "prepare": "husky",
    "upload-writing": "tsx scripts/upload-writing.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@supabase/supabase-js": "^2.103.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "14.2.5",
    "next-mdx-remote": "^6.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-github-calendar": "^5.0.6",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.0.0",
    "dotenv": "^17.4.2",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.6",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.5.4",
    "vercel": "^50.44.0",
    "vitest": "^3.2.4"
  }
}
